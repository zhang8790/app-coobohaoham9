# ============================================================================
# .env.example —— 环境变量模板（可入库；真实值写到 .env，.env 已被 gitignore）
# 用法：cp .env.example .env  后填入真实值
# ============================================================================

# 是否使用本地 mock（true=本地假数据，false=连真实 Supabase）
TARO_APP_LOCAL_DEV=false

# Supabase 项目地址与匿名公钥（anon key 为客户端公开密钥，配合 RLS 使用；
# 上线前务必执行 00081 迁移开启 RLS，否则 anon 可读写整库）
TARO_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
TARO_APP_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# 小程序 AppID
TARO_APP_APP_ID=app-xxxxxxxx
