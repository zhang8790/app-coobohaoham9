# 使用真实 Supabase 云端数据库
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 开发模式：是否使用 mock 数据（设为 false 则连接真实后端）
VITE_USE_MOCK=false

# 后台数据查询专用 service_role key（BYPASSRLS，覆盖 00081 加固后读全量需求）。
# ⚠️ 切勿把含真实密钥的 .env 提交进仓库！请把真实 key 放到 .env.local（已 gitignore）中。
# 留空则不启用特权客户端（回退 anon，行为与改动前一致）。
VITE_SUPABASE_SERVICE_ROLE_KEY=
