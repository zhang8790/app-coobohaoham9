# pnpm 11 changed strict-dep-builds default to true, which causes install to exit
# with a non-zero code when build scripts are skipped. Disable to preserve pnpm 10 behavior.
strict-dep-builds=false
# Taro 的 babel 从项目根解析 @babel/* 插件，pnpm 严格模式不会把传递依赖提升到根，
# 导致 taro build 报 "Cannot find package '@babel/plugin-proposal-decorators'"。
# 展平 node_modules 解决（已用 pnpm install 重链生效）。
shamefully-hoist=true
